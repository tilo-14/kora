# ZK compression RPC URL (e.g., Helius devnet with compression support)
ZK_COMPRESSION_RPC_URL=https://devnet.helius-rpc.com?api-key=${HELIUS_API_KEY}

# Solana devnet RPC
SOLANA_RPC_URL=https://api.devnet.solana.com

# Kora RPC URL
KORA_RPC_URL=http://localhost:8081/

# Keypairs are populated by devnet-setup.ts
# TEST_SENDER_KEYPAIR=
# DESTINATION_KEYPAIR=
# SETUP_PAYER_KEYPAIR=
# MINT_AUTHORITY=
# KORA_PRIVATE_KEY=

# SPL mint registered with Light Token Program (6 decimals)
# Populated by devnet-setup.ts
# LIGHT_TOKEN_MINT=
